{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for MCPHub desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "dialog:default",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-remove",
    "fs:scope-appconfig-recursive",
    "fs:scope-appdata-recursive",
    "fs:scope-home-recursive",
    "updater:default",
    "process:default",
    "notification:default"
  ]
}
